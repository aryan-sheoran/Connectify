# ──────────────────────────────────────────────
#  Connectify Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  Never commit .env to version control
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=connectify
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT Secrets — use long random strings (min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_long_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_long_change_this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie secret — used to sign the session cookie (any long random string)
COOKIE_SECRET=your_cookie_secret_min_32_chars_change_this

# Google OAuth 2.0
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match exactly what you register in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# MongoDB (for messages collection)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=connectify

# Redis
REDIS_URL=redis://localhost:6379

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS and post-auth redirect)
CLIENT_URL=http://localhost:3000
